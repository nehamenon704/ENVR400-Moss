qqnorm(residuals(species_lm_full_inter), main = "Residual Q-Q Plot for Visually Distinct Species Model")
qqline(residuals(species_lm_full_inter))
par(mfrow=c(1,1))
qqnorm(residuals(species_lm_full_inter), main = "Residual Q-Q Plot for Visually Distinct Species Model")
qqline(residuals(species_lm_full_inter))
summary(species_lm_full_inter)
