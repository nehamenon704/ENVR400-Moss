library(broom)
library(MASS)
library(readr)   # for read_csv
library(dplyr)   # for sample_n
#library(cowplot)
library(tidyverse)
dataset<-read_csv('combined_summarized_data.csv')
head(dataset)
kits_trees<-read.csv("kitsilano_trees_updated.csv", sep = ",", stringsAsFactors = FALSE)
rc_trees<-read.csv("renfrewcollingwood_trees_updated.csv", sep = ",", stringsAsFactors = FALSE)
#trees <- read.csv("public-trees.csv", sep = ",", stringsAsFactors = FALSE)
kits_trees <- kits_trees %>%
rename(tree_id = TREE_ID)
kits_trees<-read.csv("kitsilano_trees_updated.csv", sep = ",", stringsAsFactors = FALSE)
kits_trees<-read.csv("kitsilano_trees_updated.csv", sep = ",", stringsAsFactors = FALSE)
rc_trees<-read.csv("renfrewcollingwood_trees_updated.csv", sep = ",", stringsAsFactors = FALSE)
#trees <- read.csv("public-trees.csv", sep = ",", stringsAsFactors = FALSE)
kits_trees <- kits_trees %>%
rename(tree_id = TREE_ID)
rc_trees <- rc_trees %>%
rename(tree_id = TREE_ID)
joined_df <- inner_join(dataset, kits_trees, by = "tree_id")
joined_df2 <- inner_join(dataset, rc_trees, by = "tree_id")
final_data<-rbind(joined_df,joined_df2)
cleaned_data<-final_data%>%
group_by(GENUS_NAME,Road, neighbourhood_name)%>%
summarise(mean_bryo=mean(mean_bryo_cover,na.rm = TRUE))
View(cleaned_data)
View(final_data)
cleaned_data<-final_data%>%
group_by(GENUS_NAME,Road, neighbourhood_name)%>%
summarise(mean_bryo=mean(mean_bryo_cover,na.rm = TRUE),
mean_lichen = mean(mean_lichen_cover, na.rm = TRUE),
mean_species = mean(mean_species_count, na.rm = TRUE))
#Lichen first
#Going to try only additive to start
lichen_model_poisson_additive <- glm(mean_lichen_cover~GENUS_NAME+neighbourhood_name+Road, data = final_data)
par(mfrow = c(1,2))
plot(lichen_model_poisson_additive)
summary(lichen_model_poisson_additive)
summary(lichen_model_poisson_additive)
#Dispersion parameter
lichen_model_poisson_additive$deviance/lichen_model_poisson_additive$df.residual
#Curious to try this analysis on the square root data
sqrtlichen_model_poisson_additive <- glm(sqrt_lichen_cover~GENUS_NAME+neighbourhood_name+Road, data = final_data)
#Dispersion parameter
sqrtlichen_model_poisson_additive$deviance/sqrtlichen_model_poisson_additive$df.residual
#0.990526!!!! Very close to one. This shows promise
par(mfrow=c(1,2))
plot(sqrtlichen_model_poisson_additive)
par(mfrow=c(2,2))
plot(sqrtlichen_model_poisson_additive)
plot(lichen_model_poisson_additive)
plot(sqrtlichen_model_poisson_additive)
plot(lichen_model_poisson_additive)
plot(sqrtlichen_model_poisson_additive)
#Lichen first
#Start with linear model
ggplot(final_data, aes(x=sqrt_lichen_cover)) +geom_histogram()
ggplot(final_data, aes(x=mean_lichen_cover)) +geom_histogram()
#Lichen first
#Going to try only additive to start
#Start with linear model using sqrt lichen cover
lichen_model_linear_additive <- lm(sqrt_lichen_cover~GENUS_NAME+neighbourhood_name+Road, data = final_data)
summary(lichen_model_linear_additive)
par(mfrow=c(2,2))
plot(lichen_model_linear_additive)
#Now try poisson
lichen_model_poisson_additive <- glm(mean_lichen_cover~GENUS_NAME+neighbourhood_name+Road, family = poisson(link = 'log'), data = final_data)
#Dispersion parameter
lichen_model_poisson_additive$deviance/lichen_model_poisson_additive$df.residual
#3.466879!!!! could be worse. Not sure if this is adequate
par(mfrow=c(2,2))
plot(sqrtlichen_model_poisson_additive) #check residual normaility
#Poisson with square root data
sqrtlichen_model_poisson_additive <- glm(sqrt_lichen_cover~GENUS_NAME+neighbourhood_name+Road,
family = poisson(link = 'log'), data = final_data)
#Dispersion parameter
sqrtlichen_model_poisson_additive$deviance/sqrtlichen_model_poisson_additive$df.residual
#0.5370682!!!! This may be too underdispersed
par(mfrow=c(2,2))
plot(sqrtlichen_model_poisson_additive)
summary(sqrtlichen_model_poisson_additive)
#3.466879!!!! Too large
par(mfrow=c(2,2))
plot(lichen_model_poisson_additive) #Substansial deviation from normality, but better than regular linear model
summary(lichen_model_poisson_additive)
#Dispersion parameter
lichen_model_poisson_additive$deviance/lichen_model_poisson_additive$df.residual
#Poisson with square root data
sqrtlichen_model_poisson_additive <- glm(sqrt_lichen_cover~GENUS_NAME+neighbourhood_name+Road,
family = poisson(link = 'log'), data = final_data)
#Dispersion parameter
sqrtlichen_model_poisson_additive$deviance/sqrtlichen_model_poisson_additive$df.residual
#0.5370682!!!! This may be too underdispersed
par(mfrow=c(2,2))
plot(sqrtlichen_model_poisson_additive) #THis looks better though
summary(sqrtlichen_model_poisson_additive)
library(MASS)
lichen_model_nb_additive <- glm.nb(mean_lichen_cover~GENUS_NAME+neighbourhood_name+Road, data = final_data)
summary(lichen_model_nb_additive)
plot(lichen_model_nb_additive)
#Dispersion parameter
lichen_model_nb_additive$deviance/lichen_model_nb_additive$df.residual
#0.5370682!!!! This may be too underdispersed
plot(sqrtlichen_model_poisson_additive) #THis looks better though
summary(sqrtlichen_model_poisson_additive)
#Compare AICs to see how explantory power is different
extractAIC(lichen_model_poisson_additive)
extractAIC(sqrtlichen_model_poisson_additive)
extractAIC(lichen_model_nb_additive)
plot(lichen_model_poisson_additive) #Substansial deviation from normality, but better than regular linear model
#0.5370682!!!! This may be too underdispersed
plot(sqrtlichen_model_poisson_additive) #THis looks better though
summary(lichen_model_nb_additive)
plot(lichen_model_nb_additive) #Still issues at the tail end, maybe OK though??
##Now will try an interactive model
#Straight to negative binomial
lichen_model_nb_interactive <- glm.nb(mean_lichen_cover~GENUS_NAME*neighbourhood_name*Road, data = final_data)
plot(lichen_model_nb_interactive)
lichen_model_nb_interactive$deviance/lichen_model_nb_interactive$df.residual
summary(lichen_model_nb_interactive)
test_model <- glm.nb(mean_lichen_cover~GENUS_NAME*Road+neighbourhood_name, data = final_data)
plot(test_model)
summary(test_model)
summary(lichen_model_nb_interactive)
summary(lichen_model_nb_additive)
summary(lichen_model_nb_interactive)
plot(lichen_model_nb_interactive) #Looks OK
#
remove(test_model)
library(tidyverse)
library(MASS)
test_model <- glm.nb(mean_lichen_cover~GENUS_NAME+neighbourhood_name+Road+GENUS_NAME:Road+neighbourhood_name*Road +GENUS_NAME*neighbourhood_name,
data = final_data)
plot(test_model)
summary(test_model)
##Now will try an interactive model
#Straight to negative binomial
###### I think this should be our final model ###########
lichen_model_nb_interactive <- glm.nb(mean_lichen_cover~GENUS_NAME+neighbourhood_name+Road+GENUS_NAME:Road+neighbourhood_name*Road +GENUS_NAME*neighbourhood_name,
data = final_data) # This ignores interactions between all three variables, which don't seem that interesting and also aren't significant. I feel they kind of cloud results
plot(lichen_model_nb_interactive) #Looks OK, there is slight deviations from normaility, but TBH it's no worse than the others.
lichen_model_nb_interactive$deviance/lichen_model_nb_interactive$df.residual #Good
summary(lichen_model_nb_interactive)
plot(lichen_model_nb_additive) #Still issues at the tail end, maybe OK though??
summary(lichen_model_nb_additive)
#Other possibility is full interactive model - maybe makes more sense
lichen_model_nb_interactive_full <- glm.nb(mean_lichen_cover~GENUS_NAME*neighbourhood_name*Road,
data = final_data)
plot(lichen_model_nb_interactive_full)
lichen_model_nb_interactive_full$deviance/lichen_model_nb_interactive_full$df.residual #Good
summary(lichen_model_nb_interactive_full)
plot(lichen_model_nb_interactive) #Looks OK, there is slight deviations from normaility, but TBH it's no worse than the others.
plot(lichen_model_nb_interactive_full) ## A lot better than previous model I think
summary(lichen_model_nb_interactive_full)
